{% render 'breadcrumbs' %}

<section class="ae-page-hero" style="--ae-page-image: url({{ 'autobahn-hero.svg' | asset_url }});">
  <div class="page-width ae-page-hero__inner">
    <div>
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.text }}</p>
      <div class="ae-page-actions">
        <a class="button" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">{{ section.settings.primary_label }}</a>
        <a class="button button--secondary" href="{{ section.settings.secondary_link | default: '/pages/contact' }}">{{ section.settings.secondary_label }}</a>
      </div>
    </div>
    <div class="ae-page-stats" aria-label="Autobahn Essentials highlights">
      <div class="ae-page-stat"><strong>OEM+</strong><span>Upgrade-minded parts selection</span></div>
      <div class="ae-page-stat"><strong>Euro Focused</strong><span>BMW, Audi, VW, Mercedes and more</span></div>
      <div class="ae-page-stat"><strong>Driver Built</strong><span>Chosen for real street builds</span></div>
    </div>
  </div>
</section>

<section class="section">
  <div class="page-width ae-page-content">
    <div class="ae-split">
      <div>
        <div class="eyebrow">{{ section.settings.story_eyebrow }}</div>
        <h2>{{ section.settings.story_heading }}</h2>
      </div>
      <div class="ae-copy rte">
        {%- if page.content != blank -%}
          {{ page.content }}
        {%- else -%}
          <p>Autobahn Essentials is built for drivers who want their cars to feel sharper, stronger, and more personal. We focus on premium OEM+ and aftermarket parts that support the way enthusiasts actually build: clean fitment, reliable power, and details that make every drive feel intentional.</p>
          <p>Every category is shaped around real upgrade paths, from turbo hardware and cooling to exterior styling, interior accessories, maintenance essentials, and garage gear.</p>
        {%- endif -%}
      </div>
    </div>

    <div class="ae-grid-3">
      <div class="ae-card ae-card--accent">
        <div class="eyebrow">Performance</div>
        <h3>Parts with purpose</h3>
        <p>Products are selected around real build goals: better response, cleaner airflow, stronger cooling, and sharper presentation.</p>
      </div>
      <div class="ae-card ae-card--accent">
        <div class="eyebrow">Fitment</div>
        <h3>Confidence before checkout</h3>
        <p>Vehicle-focused guidance helps customers shop by platform, part type, and upgrade path.</p>
      </div>
      <div class="ae-card ae-card--accent">
        <div class="eyebrow">Community</div>
        <h3>Built with enthusiasts</h3>
        <p>AE is designed around the drivers, builders, and detail-obsessed owners who keep car culture moving.</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Autobahn page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Autobahn Essentials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built For Drivers"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Hero text",
      "default": "Performance parts, OEM+ upgrades, and garage essentials for European builds."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Parts"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "story_eyebrow",
      "label": "Story eyebrow",
      "default": "Our Standard"
    },
    {
      "type": "text",
      "id": "story_heading",
      "label": "Story heading",
      "default": "Premium parts for builds that get driven."
    }
  ]
}
{% endschema %}
