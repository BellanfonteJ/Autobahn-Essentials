{% render 'breadcrumbs' %}

<section class="ae-page-hero" style="--ae-page-image: url({{ 'autobahn-hero.svg' | asset_url }});">
  <div class="page-width ae-page-hero__inner">
    <div>
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.text }}</p>
    </div>
    <div class="ae-page-stats" aria-label="Contact highlights">
      <div class="ae-page-stat"><strong>Orders</strong><span>Tracking, shipping, and returns</span></div>
      <div class="ae-page-stat"><strong>Fitment</strong><span>Vehicle and part compatibility</span></div>
      <div class="ae-page-stat"><strong>Builds</strong><span>Product advice for your setup</span></div>
    </div>
  </div>
</section>

<section class="section">
  <div class="page-width ae-contact-layout">
    <div class="ae-card">
      <div class="eyebrow">Message AE</div>
      <h2>{{ section.settings.form_heading }}</h2>
      {%- form 'contact', class: 'ae-contact-form' -%}
        {%- if form.posted_successfully? -%}
          <div class="ae-form-status">{{ section.settings.success_text }}</div>
        {%- endif -%}
        {%- if form.errors -%}
          <div class="ae-form-status">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        <input class="field" type="text" name="contact[name]" placeholder="Name" required>
        <input class="field" type="email" name="contact[email]" placeholder="Email" required>
        <input class="field" type="text" name="contact[vehicle]" placeholder="Vehicle">
        <select class="field" name="contact[topic]">
          <option value="Fitment check">Fitment check</option>
          <option value="Order support">Order support</option>
          <option value="Build advice">Build advice</option>
          <option value="Wholesale">Wholesale</option>
        </select>
        <textarea class="field" name="contact[body]" placeholder="Tell us what you need" required></textarea>
        <button class="button" type="submit">{{ section.settings.button_label }}</button>
      {%- endform -%}
    </div>

    <div class="ae-page-content">
      <div class="ae-card ae-card--accent">
        <div class="eyebrow">Email</div>
        <h3>{{ shop.email | default: section.settings.fallback_email }}</h3>
        <p>{{ section.settings.email_text }}</p>
      </div>
      <div class="ae-card ae-card--accent">
        <div class="eyebrow">Instagram</div>
        <h3>@autobahnessentials</h3>
        <p>{{ section.settings.instagram_text }}</p>
        <a class="button button--secondary" href="https://www.instagram.com/autobahnessentials/" target="_blank" rel="noopener noreferrer">Open Instagram</a>
      </div>
      <div class="ae-card ae-card--accent">
        <div class="eyebrow">Response time</div>
        <h3>{{ section.settings.response_heading }}</h3>
        <p>{{ section.settings.response_text }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Contact Autobahn Essentials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Talk Parts With Us"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Hero text",
      "default": "Ask about fitment, orders, product recommendations, and build-focused upgrade paths."
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form heading",
      "default": "Send your question"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Send Message"
    },
    {
      "type": "text",
      "id": "success_text",
      "label": "Success text",
      "default": "Message received. The AE team will get back to you soon."
    },
    {
      "type": "text",
      "id": "fallback_email",
      "label": "Fallback email",
      "default": "support@autobahnessentials.com"
    },
    {
      "type": "textarea",
      "id": "email_text",
      "label": "Email text",
      "default": "Use email for order questions, fitment details, returns, and product support."
    },
    {
      "type": "textarea",
      "id": "instagram_text",
      "label": "Instagram text",
      "default": "Follow product drops, builds, and behind-the-scenes AE content."
    },
    {
      "type": "text",
      "id": "response_heading",
      "label": "Response heading",
      "default": "Fast, focused replies"
    },
    {
      "type": "textarea",
      "id": "response_text",
      "label": "Response text",
      "default": "Include your vehicle details and order number when relevant so support can move quickly."
    }
  ]
}
{% endschema %}
