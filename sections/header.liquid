{%- if settings.show_ticker -%}
  <div class="announcement-bar">
    <div class="ticker-banner" role="region" aria-label="Autobahn Essentials parts ticker">
      <div class="ticker-banner__track">
        {%- for i in (1..3) -%}
          <div class="ticker-banner__group"{% unless forloop.first %} aria-hidden="true"{% endunless %}>
            <span>{{ settings.ticker_text }}</span>
            <span>OEM+ Performance Parts</span>
            <span>Turbo Upgrades</span>
            <span>Downpipes</span>
            <span>Intercoolers</span>
            <span>Carbon Fiber Exterior</span>
            <span>Interior Accessories</span>
            <span>Euro Builds</span>
            <span>Fast Shipping</span>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

<header class="site-header{% if settings.enable_sticky_header %} site-header--sticky{% endif %}">
  <div class="site-header__inner page-width">
    <button class="icon-button mobile-menu-trigger" type="button" data-menu-toggle aria-expanded="false" aria-controls="SiteNav">
      <span class="visually-hidden">{{ 'sections.header.menu' | t }}</span>
      {% render 'icon', icon: 'menu' %}
    </button>

    <nav id="SiteNav" class="site-nav" data-mobile-nav aria-label="{{ 'sections.header.navigation' | t }}">
      {%- if section.settings.menu.links.size > 0 -%}
        {%- assign has_home_link = false -%}
        {%- assign has_builds_link = false -%}
        {%- assign has_contacts_link = false -%}

        {%- for link in section.settings.menu.links -%}
          {%- assign link_title = link.title | downcase | strip -%}
          {%- if link_title == 'home' -%}
            {%- assign has_home_link = true -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endif -%}
        {%- endfor -%}
        {%- unless has_home_link -%}
          <a href="{{ routes.root_url }}">Home</a>
        {%- endunless -%}

        {% render 'category-dropdown', label: 'Shop' %}

        {%- for link in section.settings.menu.links -%}
          {%- assign link_title = link.title | downcase | strip -%}
          {%- if link_title == 'builds' or link_title contains 'build' -%}
            {%- assign has_builds_link = true -%}
            <a href="{{ link.url }}">Builds</a>
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
        {%- unless has_builds_link -%}
          <a href="/pages/builds">Builds</a>
        {%- endunless -%}

        {%- for link in section.settings.menu.links -%}
          {%- assign link_title = link.title | downcase | strip -%}
          {%- if link_title contains 'contact' -%}
            {%- assign has_contacts_link = true -%}
            <a href="{{ link.url }}">Contacts</a>
          {%- endif -%}
        {%- endfor -%}
        {%- unless has_contacts_link -%}
          <a href="/pages/contact">Contacts</a>
        {%- endunless -%}

        {%- for link in section.settings.menu.links -%}
          {%- assign link_title = link.title | downcase | strip -%}
          {%- if link_title == 'home' or link_title contains 'contact' or link_title contains 'build' or link_title contains 'shop' or link_title contains 'categor' or link_title == 'bmw' or link_title == 'audi' or link_title == 'vw' or link_title == 'volkswagen' -%}
            {%- continue -%}
          {%- endif -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="{{ routes.root_url }}">Home</a>
        {% render 'category-dropdown', label: 'Shop' %}
        <a href="/pages/builds">Builds</a>
        <a href="/pages/contact">Contacts</a>
      {%- endif -%}
    </nav>

    <div class="header-logo">
      <a href="{{ routes.root_url }}" class="site-logo">
        {%- if settings.logo != blank -%}
          {{ settings.logo | image_url: width: 420 | image_tag: loading: 'eager', alt: shop.name }}
        {%- else -%}
          <img src="{{ 'autobahn-essentials-logo.png' | asset_url }}" alt="{{ shop.name | default: 'Autobahn Essentials' | escape }}" width="940" height="430" loading="eager">
        {%- endif -%}
        <span class="site-logo__text" aria-hidden="true">{{ shop.name | default: 'Autobahn Essentials' }}</span>
      </a>
    </div>

    <div class="header-actions">
      <button class="icon-button garage-toggle" type="button" data-garage-toggle aria-expanded="false" aria-controls="MyGarage">
        <span class="visually-hidden">{{ 'sections.header.garage' | t }}</span>
        {% render 'icon', icon: 'garage' %}
        <span class="garage-toggle__indicator" data-garage-indicator hidden></span>
      </button>
      <button class="icon-button" type="button" data-search-toggle aria-expanded="false" aria-controls="HeaderSearch">
        <span class="visually-hidden">{{ 'general.search.search' | t }}</span>
        {% render 'icon', icon: 'search' %}
      </button>
      <a class="icon-button" href="{{ routes.cart_url }}" data-cart-drawer-open aria-controls="CartDrawer" aria-expanded="false">
        <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
        {% render 'icon', icon: 'cart' %}
        {%- if cart.item_count > 0 -%}
          <span class="cart-count" data-cart-count>{{ cart.item_count }}</span>
        {%- else -%}
          <span class="cart-count" data-cart-count hidden>0</span>
        {%- endif -%}
      </a>
    </div>
  </div>

  <div id="HeaderSearch" class="search-drawer" data-search-drawer>
    <div class="page-width">
      <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
        <input class="field" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}">
        <button class="button" type="submit">{{ 'general.search.submit' | t }}</button>
      </form>
    </div>
  </div>

  {% render 'my-garage-drawer' %}
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
