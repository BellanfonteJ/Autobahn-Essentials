{% render 'breadcrumbs' %}

<section class="ae-page-hero" style="--ae-page-image: url({{ 'autobahn-hero.svg' | asset_url }});">
  <div class="page-width ae-page-hero__inner">
    <div>
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.text }}</p>
    </div>
    <div class="ae-page-stats" aria-label="Fitment highlights">
      <div class="ae-page-stat"><strong>Year</strong><span>Start with the exact model year</span></div>
      <div class="ae-page-stat"><strong>Chassis</strong><span>Match the platform and engine</span></div>
      <div class="ae-page-stat"><strong>Parts</strong><span>Check hardware and install notes</span></div>
    </div>
  </div>
</section>

<section class="section">
  <div class="page-width ae-page-content">
    <div class="ae-card ae-card--accent">
      <div class="eyebrow">Find your fit</div>
      <form class="ae-fitment-form" action="{{ routes.search_url }}" method="get" role="search" data-vehicle-finder data-garage-save>
        <input type="hidden" name="type" value="product">
        <input type="hidden" name="q" value="">
        <select class="select" name="vehicle_year">
          <option value="">Year</option>
        </select>
        <select class="select" name="vehicle_make">
          <option value="">Make</option>
          <option>BMW</option>
          <option>Audi</option>
          <option>Volkswagen</option>
        </select>
        <select class="select" name="vehicle_model">
          <option value="">Model</option>
        </select>
        <select class="select" name="vehicle_chassis">
          <option value="">Chassis</option>
        </select>
        <select class="select" name="vehicle_trim">
          <option value="">Trim / Engine</option>
        </select>
        <select class="select" name="part_type">
          <option value="">Part type</option>
          <option>Downpipes</option>
          <option>Turbo upgrade</option>
          <option>Intercooler</option>
          <option>Engine performance</option>
          <option>Exterior styling</option>
          <option>Interior accessories</option>
        </select>
        <button class="button" type="submit">{{ section.settings.search_label }}</button>
      </form>
    </div>

    <div class="ae-grid-3">
      <div class="ae-card">
        <div class="eyebrow">Step 01</div>
        <h3>Confirm the platform</h3>
        <p>Use year, make, model, chassis code, and engine code before choosing performance hardware.</p>
      </div>
      <div class="ae-card">
        <div class="eyebrow">Step 02</div>
        <h3>Match the goal</h3>
        <p>Daily OEM+, street power, track prep, and styling builds need different supporting parts.</p>
      </div>
      <div class="ae-card">
        <div class="eyebrow">Step 03</div>
        <h3>Check install needs</h3>
        <p>Review gaskets, clamps, hardware, coding, tuning, and maintenance items before checkout.</p>
      </div>
    </div>

    <div class="ae-split">
      <div>
        <div class="eyebrow">{{ section.settings.help_eyebrow }}</div>
        <h2>{{ section.settings.help_heading }}</h2>
      </div>
      <div class="ae-card">
        <ul class="ae-check-list">
          <li>Send your VIN, year, make, model, engine, and current modifications.</li>
          <li>Include the part you are considering and your performance goal.</li>
          <li>Share photos of current hardware when fitment is tight or platform-specific.</li>
        </ul>
        <a class="button" href="{{ section.settings.contact_link | default: '/pages/contact' }}">{{ section.settings.contact_label }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fitment guide page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Fitment Guide"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Buy The Right Part"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Hero text",
      "default": "Match your vehicle, build goal, and install requirements before ordering performance parts."
    },
    {
      "type": "text",
      "id": "search_label",
      "label": "Search button label",
      "default": "Search Parts"
    },
    {
      "type": "text",
      "id": "help_eyebrow",
      "label": "Help eyebrow",
      "default": "Need a fitment check?"
    },
    {
      "type": "text",
      "id": "help_heading",
      "label": "Help heading",
      "default": "Send the details before you buy."
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Contact button label",
      "default": "Contact Fitment Support"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact button link"
    }
  ]
}
{% endschema %}
