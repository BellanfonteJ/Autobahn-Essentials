<section class="spec-strip section--tight">
  <div class="page-width">
    <div class="spec-strip__grid">
      {%- for block in section.blocks -%}
        <div class="spec-item" tabindex="0" {{ block.shopify_attributes }}>
          {% render 'icon', icon: block.settings.icon %}
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Spec strip",
  "settings": [],
  "blocks": [
    {
      "type": "item",
      "name": "Spec",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield" },
            { "value": "truck", "label": "Truck" },
            { "value": "bolt", "label": "Bolt" },
            { "value": "star", "label": "Star" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Performance Tested"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Every part selected for real-world performance and quality."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Spec strip",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "shield",
            "heading": "Performance Tested",
            "text": "Every part selected for real-world performance and quality."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "bolt",
            "heading": "Enthusiast Owned",
            "text": "Built by car people, for car people."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "truck",
            "heading": "Euro Focused",
            "text": "Specializing in BMW, Audi, VW, and more."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "star",
            "heading": "Fast Shipping",
            "text": "Quick processing and reliable delivery."
          }
        }
      ]
    }
  ]
}
{% endschema %}
