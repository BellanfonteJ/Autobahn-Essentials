<section class="section">
  <div class="page-width image-text">
    <div class="image-text__media">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 50vw, 100vw' }}
      {%- else -%}
        <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=1500&q=80&auto=format&fit=crop" alt="Modified euro car" loading="lazy" sizes="(min-width: 990px) 50vw, 100vw">
      {%- endif -%}
    </div>

    <div class="image-text__content">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
      <div class="feature-list">
        {%- for block in section.blocks -%}
          <div class="feature-list__item" {{ block.shopify_attributes }}>
            {% render 'icon', icon: 'bolt' %}
            <span>{{ block.settings.text }}</span>
          </div>
        {%- endfor -%}
      </div>
      {%- if section.settings.button_label != blank -%}
        <a class="button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Real builds. Real results."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted By Enthusiasts"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Shop parts with confidence: selected for quality, packed for quick turnaround, and backed by support that understands European builds."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Confident, straightforward, performance-driven product pages."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with text",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "text": "Quality-vetted OEM+ and aftermarket parts selected for real builds."
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Fast order processing and shipping on in-stock essentials."
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Fitment-minded help for choosing the right upgrade before you buy."
          }
        }
      ]
    }
  ]
}
{% endschema %}
