{% render 'breadcrumbs' %}

<section class="ae-page-hero" style="--ae-page-image: url({{ 'autobahn-hero.svg' | asset_url }});">
  <div class="page-width ae-page-hero__inner">
    <div>
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.text }}</p>
      <div class="ae-page-actions">
        <a class="button" href="{{ section.settings.contact_link | default: '/pages/contact' }}">{{ section.settings.contact_label }}</a>
      </div>
    </div>
    <div class="ae-page-stats" aria-label="FAQ highlights">
      <div class="ae-page-stat"><strong>Fitment</strong><span>Vehicle compatibility questions</span></div>
      <div class="ae-page-stat"><strong>Orders</strong><span>Shipping and support details</span></div>
      <div class="ae-page-stat"><strong>Builds</strong><span>Parts and upgrade advice</span></div>
    </div>
  </div>
</section>

<section class="section">
  <div class="page-width ae-split">
    <div>
      <div class="eyebrow">{{ section.settings.list_eyebrow }}</div>
      <h2>{{ section.settings.list_heading }}</h2>
    </div>
    <div class="ae-faq-list">
      {%- for block in section.blocks -%}
        <details {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}</summary>
          <div class="ae-faq-list__answer">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Answers Before Checkout"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Hero text",
      "default": "Quick answers for fitment, ordering, shipping, returns, and build advice."
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Contact button label",
      "default": "Contact Support"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact button link"
    },
    {
      "type": "text",
      "id": "list_eyebrow",
      "label": "List eyebrow",
      "default": "Common questions"
    },
    {
      "type": "text",
      "id": "list_heading",
      "label": "List heading",
      "default": "What drivers ask most."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How do I confirm fitment?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Match the product to your year, make, model, chassis, engine, and existing modifications. Contact support with your vehicle details when you need a second look."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ page",
      "blocks": [
        {
          "type": "faq"
        },
        {
          "type": "faq",
          "settings": {
            "question": "Do you offer help choosing parts?",
            "answer": "Yes. Send your vehicle, current modifications, goals, and the parts you are considering so we can point you toward the right upgrade path."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "When will my order ship?",
            "answer": "In-stock orders are prepared as quickly as possible. Tracking details are shared when available."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Can I return a part after installation?",
            "answer": "Installed, modified, painted, coated, or used parts are difficult to review for returns. Inspect every item before installation."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How do I submit my build?",
            "answer": "Tag @autobahnessentials on Instagram with your vehicle, parts list, and build goals."
          }
        }
      ]
    }
  ]
}
{% endschema %}
