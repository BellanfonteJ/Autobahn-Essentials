<section class="section">
  <div class="page-width">
    <div class="section-heading">
      <div>
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        <h2>{{ section.settings.heading }}</h2>
      </div>
    </div>

    {%- assign collection_fallback_images = 'fallback-collection-1.jpg,fallback-collection-2.jpg,fallback-collection-3.jpg,fallback-collection-4.jpg,fallback-collection-5.jpg,fallback-collection-6.jpg' | split: ',' -%}
    <div class="collection-grid">
      {%- for block in section.blocks -%}
        {%- assign collection = block.settings.collection -%}
        <a class="collection-card" href="{{ collection.url | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
          <div class="collection-card__media">
            {%- if collection.featured_image -%}
              {{ collection.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', decoding: 'async', sizes: '(min-width: 990px) 25vw, (min-width: 361px) 50vw, 100vw' }}
            {%- elsif block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', decoding: 'async', sizes: '(min-width: 990px) 25vw, (min-width: 361px) 50vw, 100vw' }}
            {%- else -%}
              {%- assign placeholder_index = forloop.index0 | modulo: collection_fallback_images.size -%}
              <img src="{{ collection_fallback_images[placeholder_index] | asset_url }}" alt="" width="900" height="600" loading="lazy" decoding="async" sizes="(min-width: 990px) 25vw, (min-width: 361px) 50vw, 100vw">
            {%- endif -%}
          </div>
          <div class="collection-card__info">
            <h3 class="collection-card__title">{{ collection.title | default: block.settings.title }}</h3>
            <span class="eyebrow">{{ 'collections.general.view_all' | t }}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collections",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop by category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By Category"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Fallback image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Fallback title",
          "default": "Performance"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collections",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "title": "Engine Performance"
          }
        },
        {
          "type": "collection",
          "settings": {
            "title": "Turbo Upgrades"
          }
        },
        {
          "type": "collection",
          "settings": {
            "title": "Exterior Styling"
          }
        },
        {
          "type": "collection",
          "settings": {
            "title": "Interior Accessories"
          }
        }
      ]
    }
  ]
}
{% endschema %}
