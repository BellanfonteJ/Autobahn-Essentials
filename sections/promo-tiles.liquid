{%- assign promo_placeholders = 'photo-1542362567-b07e54358753,photo-1555215695-3004980ad54e,photo-1583121274602-3e2820c69888,photo-1605559424843-9e4c228bf1c2,photo-1485827404703-89b55fcc595e,photo-1606664515524-ed2f786a0bd6' | split: ',' -%}
<section class="section section--tight">
  <div class="page-width">
    <div class="promo-tiles">
      {%- for block in section.blocks -%}
        <a class="promo-tile" href="{{ block.settings.link | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 33vw, 100vw' }}
          {%- else -%}
            {%- assign placeholder_index = forloop.index0 | modulo: promo_placeholders.size -%}
            <img src="https://images.unsplash.com/{{ promo_placeholders[placeholder_index] }}?w=900&q=80&auto=format&fit=crop" alt="" loading="lazy" sizes="(min-width: 990px) 33vw, 100vw">
          {%- endif -%}
          <span class="eyebrow">{{ block.settings.eyebrow }}</span>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo tiles",
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Build path"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "600HP Build"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Shop proven upgrade stacks for serious Euro builds."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo tiles",
      "blocks": [
        {
          "type": "tile",
          "settings": {
            "eyebrow": "Product drop",
            "heading": "New Turbo Upgrades",
            "text": "Upgraded performance built to last."
          }
        },
        {
          "type": "tile",
          "settings": {
            "eyebrow": "Build feature",
            "heading": "600HP Build",
            "text": "Explore parts for high-output street setups."
          }
        },
        {
          "type": "tile",
          "settings": {
            "eyebrow": "OEM+ essentials",
            "heading": "Daily Driver Ready",
            "text": "Clean upgrades for fit, finish, and reliability."
          }
        }
      ]
    }
  ]
}
{% endschema %}
