<section class="hero">
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', sizes: '100vw' }}
    {%- else -%}
      <img src="https://images.unsplash.com/photo-1741889823656-c056b0c43749?w=2400&q=80&auto=format&fit=crop" alt="BMW M4 at sunset" loading="eager" sizes="100vw">
    {%- endif -%}
  </div>

  <div class="hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h1>
      <span>{{ section.settings.heading }}</span>
      {%- if section.settings.accent_heading != blank -%}
        <em>{{ section.settings.accent_heading }}</em>
      {%- endif -%}
    </h1>
    <p class="hero__copy">{{ section.settings.text }}</p>
    <div class="hero__actions">
      {%- if section.settings.primary_label != blank -%}
        <a class="button" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
          {{ section.settings.primary_label }}
          {% render 'icon', icon: 'arrow' %}
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_label != blank -%}
        <a class="button button--secondary" href="{{ section.settings.secondary_link | default: '/pages/builds' }}">
          {{ section.settings.secondary_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<div class="hero__stats">
  <div class="hero-stat">
    <strong>{{ section.settings.stat_1 }}</strong>
    <span>{{ section.settings.stat_label_1 }}</span>
  </div>
  <div class="hero-stat">
    <strong>{{ section.settings.stat_2 }}</strong>
    <span>{{ section.settings.stat_label_2 }}</span>
  </div>
  <div class="hero-stat">
    <strong>{{ section.settings.stat_3 }}</strong>
    <span>{{ section.settings.stat_label_3 }}</span>
  </div>
</div>

{% schema %}
{
  "name": "Autobahn hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Autobahn Essentials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built For"
    },
    {
      "type": "text",
      "id": "accent_heading",
      "label": "Accent heading",
      "default": "Performance."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Premium OEM+ and aftermarket parts for Euro builds."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View Builds"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "stat_1",
      "label": "Stat 1",
      "default": "OEM+"
    },
    {
      "type": "text",
      "id": "stat_label_1",
      "label": "Stat label 1",
      "default": "Quality parts"
    },
    {
      "type": "text",
      "id": "stat_2",
      "label": "Stat 2",
      "default": "Euro"
    },
    {
      "type": "text",
      "id": "stat_label_2",
      "label": "Stat label 2",
      "default": "Build focus"
    },
    {
      "type": "text",
      "id": "stat_3",
      "label": "Stat 3",
      "default": "Fast"
    },
    {
      "type": "text",
      "id": "stat_label_3",
      "label": "Stat label 3",
      "default": "Shipping"
    }
  ],
  "presets": [
    {
      "name": "Autobahn hero"
    }
  ]
}
{% endschema %}
