<section class="hero">
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', sizes: '100vw' }}
    {%- else -%}
      <img src="{{ 'fallback-hero-bmw-m4.jpg' | asset_url }}" alt="BMW M4 at sunset" width="1800" height="1200" loading="eager" sizes="100vw">
    {%- endif -%}
  </div>

  <div class="hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    {%- assign hero_heading = section.settings.heading | default: 'Built For' -%}
    {%- assign hero_accent = section.settings.accent_heading | default: 'Performance.' -%}
    {%- assign hero_accent_text = hero_accent -%}
    {%- assign hero_period = '' -%}
    {%- assign hero_accent_last = hero_accent | slice: -1 -%}
    {%- if hero_accent_last == '.' -%}
      {%- assign hero_accent_text = hero_accent | remove_last: '.' -%}
      {%- assign hero_period = '.' -%}
    {%- endif -%}
    {%- assign hero_heading_duration = hero_heading.size | times: 70 -%}
    {%- assign hero_accent_duration = hero_accent.size | times: 70 -%}
    {%- assign hero_period_delay = hero_heading_duration | plus: hero_accent_duration -%}
    <h1
      class="hero-typewriter"
      style="
        --hero-heading-chars: {{ hero_heading.size }};
        --hero-heading-duration: {{ hero_heading_duration }}ms;
        --hero-accent-chars: {{ hero_accent.size }};
        --hero-accent-duration: {{ hero_accent_duration }}ms;
        --hero-accent-delay: {{ hero_heading_duration }}ms;
        --hero-period-delay: {{ hero_period_delay }}ms;
      "
    >
      <span class="hero-typewriter__line">
        <span class="hero-typewriter__reserve" aria-hidden="true">{{ hero_heading }}</span>
        <span class="hero-typewriter__typing">{{ hero_heading }}</span>
      </span>
      {%- if section.settings.accent_heading != blank -%}
        <em class="hero-typewriter__line hero-typewriter__line--accent">
          <span class="hero-typewriter__reserve" aria-hidden="true">{{ hero_accent }}</span>
          <span class="hero-typewriter__typing hero-typewriter__typing--accent">
            {{- hero_accent_text -}}<span class="hero-typewriter__period">{{ hero_period }}</span>
          </span>
        </em>
      {%- endif -%}
    </h1>
    <p class="hero__copy">{{ section.settings.text }}</p>
    <div class="hero__actions">
      {%- if section.settings.primary_label != blank -%}
        <a class="button" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
          {{ section.settings.primary_label }}
          {% render 'icon', icon: 'arrow' %}
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_label != blank -%}
        <a class="button button--secondary" href="{{ section.settings.secondary_link | default: '/pages/builds' }}">
          {{ section.settings.secondary_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Autobahn hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Autobahn Essentials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built For"
    },
    {
      "type": "text",
      "id": "accent_heading",
      "label": "Accent heading",
      "default": "Performance."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Premium OEM+ and aftermarket parts for Euro builds."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View Builds"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Autobahn hero"
    }
  ]
}
{% endschema %}
