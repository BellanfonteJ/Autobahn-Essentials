<section class="hero">
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', sizes: '100vw' }}
    {%- else -%}
      <img src="{{ 'fallback-hero-orange-lamborghini.jpg' | asset_url }}" alt="Orange Lamborghini Aventador parked on gray pavement" width="2400" height="1600" loading="eager" sizes="100vw">
    {%- endif -%}
  </div>

  <div class="hero__content">
    <h1
      class="hero-typewriter"
      data-hero-typewriter
      data-hero-typewriter-sequence="Built For|Performance;Built For|Drivers;Backed By|Passion;Autobahn|Essentials"
      aria-label="Built For Performance. Built For Drivers. Backed By Passion. Autobahn Essentials."
    >
      <span class="hero-typewriter__line">
        <span class="hero-typewriter__reserve" aria-hidden="true">Backed By</span>
        <span class="hero-typewriter__typing" data-hero-typewriter-base></span>
      </span>
      <em class="hero-typewriter__line hero-typewriter__line--accent">
        <span class="hero-typewriter__reserve" aria-hidden="true">Performance.</span>
        <span class="hero-typewriter__typing hero-typewriter__typing--accent">
          <span data-hero-typewriter-accent></span><span class="hero-typewriter__period" data-hero-typewriter-period></span>
        </span>
      </em>
    </h1>
    <p class="hero__copy">{{ section.settings.text }}</p>
    <div class="hero__actions">
      {%- if section.settings.primary_label != blank -%}
        <a class="button" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
          {{ section.settings.primary_label }}
          {% render 'icon', icon: 'arrow' %}
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_label != blank -%}
        <a class="button button--secondary" href="{{ section.settings.secondary_link | default: '/pages/builds' }}">
          {{ section.settings.secondary_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Autobahn hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Autobahn Essentials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built For"
    },
    {
      "type": "text",
      "id": "accent_heading",
      "label": "Accent heading",
      "default": "Performance."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Premium OEM+ and aftermarket parts for Euro builds."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View Builds"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Autobahn hero"
    }
  ]
}
{% endschema %}
