<section class="vehicle-finder section--tight">
  <div class="page-width">
    <div class="vehicle-finder__shell">
      <div>
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        <h2>{{ section.settings.heading }}</h2>
      </div>

      <div class="vehicle-finder__right">
        <div class="vehicle-finder__saved" data-vehicle-saved hidden>
          <span class="eyebrow">Your vehicle</span>
          <span class="vehicle-finder__saved-text" data-vehicle-saved-text></span>
          <button type="button" class="vehicle-finder__clear" data-vehicle-clear>Clear</button>
        </div>

        <form class="vehicle-finder__form" action="{{ routes.search_url }}" method="get" data-vehicle-finder data-garage-save>
          <input type="hidden" name="type" value="product">
          <input type="hidden" name="q" value="">

          <label class="visually-hidden" for="FinderYear-{{ section.id }}">Year</label>
          <select class="select" id="FinderYear-{{ section.id }}" name="vehicle_year">
            <option value="">Year</option>
          </select>

          <label class="visually-hidden" for="FinderMake-{{ section.id }}">Make</label>
          <select class="select" id="FinderMake-{{ section.id }}" name="vehicle_make">
            <option value="">Make</option>
            <option>BMW</option>
            <option>Audi</option>
            <option>Volkswagen</option>
          </select>

          <label class="visually-hidden" for="FinderModel-{{ section.id }}">Model</label>
          <select class="select" id="FinderModel-{{ section.id }}" name="vehicle_model">
            <option value="">Model</option>
          </select>

          <label class="visually-hidden" for="FinderChassis-{{ section.id }}">Chassis</label>
          <select class="select" id="FinderChassis-{{ section.id }}" name="vehicle_chassis">
            <option value="">Chassis</option>
          </select>

          <label class="visually-hidden" for="FinderTrim-{{ section.id }}">Trim / Engine</label>
          <select class="select" id="FinderTrim-{{ section.id }}" name="vehicle_trim">
            <option value="">Trim / Engine</option>
          </select>

          <label class="visually-hidden" for="FinderPart-{{ section.id }}">Part type</label>
          <select class="select" id="FinderPart-{{ section.id }}" name="part_type">
            <option value="">Part type</option>
            <option>Downpipes</option>
            <option>Turbo upgrade</option>
            <option>Intercooler</option>
            <option>Engine performance</option>
            <option>Exterior styling</option>
            <option>Interior accessories</option>
          </select>

          <button class="button" type="submit">
            {{ section.settings.button_label }}
            {% render 'icon', icon: 'search' %}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Vehicle finder",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Find your fit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Search by vehicle, category, or upgrade path"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Find Parts"
    }
  ],
  "presets": [
    {
      "name": "Vehicle finder"
    }
  ]
}
{% endschema %}
