{%- assign password_heading = section.settings.heading | default: 'Autobahn Essentials' -%}
{%- assign password_accent = section.settings.accent_heading | default: 'Coming Soon.' -%}
{%- assign password_accent_text = password_accent -%}
{%- assign password_period = '' -%}
{%- assign password_accent_last = password_accent | slice: -1 -%}
{%- if password_accent_last == '.' -%}
  {%- assign password_accent_text = password_accent | remove_last: '.' -%}
  {%- assign password_period = '.' -%}
{%- endif -%}
{%- assign password_heading_duration = password_heading.size | times: 70 -%}
{%- assign password_accent_duration = password_accent.size | times: 70 -%}
{%- assign password_period_delay = password_heading_duration | plus: password_accent_duration -%}

<section class="password-hero">
  <div class="password-hero__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', sizes: '100vw' }}
    {%- else -%}
      <img src="{{ 'fallback-hero-orange-lamborghini.jpg' | asset_url }}" alt="Orange Lamborghini Aventador parked on gray pavement" width="2400" height="1600" loading="eager" sizes="100vw">
    {%- endif -%}
  </div>

  <div class="password-hero__inner">
    <div class="password-hero__content">
      <h1
        class="hero-typewriter password-hero__heading"
        style="
          --hero-heading-chars: {{ password_heading.size }};
          --hero-heading-duration: {{ password_heading_duration }}ms;
          --hero-accent-chars: {{ password_accent.size }};
          --hero-accent-duration: {{ password_accent_duration }}ms;
          --hero-accent-delay: {{ password_heading_duration }}ms;
          --hero-period-delay: {{ password_period_delay }}ms;
        "
      >
        <span class="hero-typewriter__line">
          <span class="hero-typewriter__reserve" aria-hidden="true">{{ password_heading }}</span>
          <span class="hero-typewriter__typing">{{ password_heading }}</span>
        </span>
        <em class="hero-typewriter__line hero-typewriter__line--accent">
          <span class="hero-typewriter__reserve" aria-hidden="true">{{ password_accent }}</span>
          <span class="hero-typewriter__typing hero-typewriter__typing--accent">
            {{- password_accent_text -}}<span class="hero-typewriter__period">{{ password_period }}</span>
          </span>
        </em>
      </h1>

      {%- form 'storefront_password', class: 'password-form' -%}
        {%- if form.errors -%}
          <div class="password-form__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}
        <div class="password-form__row">
          <label class="visually-hidden" for="Password">Password</label>
          <input
            id="Password"
            class="field password-form__input"
            type="password"
            name="password"
            autocomplete="current-password"
            placeholder="Dev Password"
          >
          <button class="button password-form__button" type="submit">Enter</button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Password page",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Autobahn Essentials"
    },
    {
      "type": "text",
      "id": "accent_heading",
      "label": "Accent heading",
      "default": "Coming Soon."
    }
  ]
}
{% endschema %}
