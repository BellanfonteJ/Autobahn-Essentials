<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_background }}">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- else -%}
      <link rel="icon" type="image/png" href="{{ 'favicon-ae.png' | asset_url }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {{ content_for_header }}

    <style>
      @font-face {
        font-family: "Montserrat";
        font-style: normal;
        font-weight: 800 900;
        font-display: swap;
        src: url("{{ 'montserrat-latin-800-900.woff2' | asset_url }}") format("woff2");
      }

      @font-face {
        font-family: "Roboto";
        font-style: normal;
        font-weight: 400 900;
        font-display: swap;
        src: url("{{ 'roboto-latin-400-900.woff2' | asset_url }}") format("woff2");
      }

      :root {
        --color-background: {{ settings.color_background }};
        --color-surface: {{ settings.color_surface }};
        --color-surface-strong: {{ settings.color_surface_strong }};
        --color-text: {{ settings.color_text }};
        --color-muted: {{ settings.color_muted }};
        --color-accent: {{ settings.color_accent }};
        --color-accent-contrast: {{ settings.color_accent_contrast }};
        --color-line: {{ settings.color_line }};
        --page-width: {{ settings.page_width }}px;
        --font-heading: "Montserrat", Arial Black, Impact, sans-serif;
        --font-body: "Roboto", Arial, sans-serif;
      }
    </style>
    {{ 'base.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  </head>

  <body class="template-{{ template.name | handle }}{% if settings.show_ticker %} has-floating-ticker{% endif %}">
    <a class="skip-to-content-link button button--secondary" href="#MainContent">
      {{ 'accessibility.skip_to_content' | t }}
    </a>

    {% section 'header' %}

    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <button class="back-to-top" type="button" data-back-to-top aria-label="Back to top">
      {% render 'icon', icon: 'arrow' %}
    </button>
  </body>
</html>
