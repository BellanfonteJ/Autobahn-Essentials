{%- liquid
  assign sizes = '(min-width: 990px) 25vw, (min-width: 361px) 50vw, 100vw'
  assign product_tags = product.tags | join: ' '
  assign fitment_source = product.title | append: ' ' | append: product.type | append: ' ' | append: product_tags | append: ' ' | append: product.description
  assign seo_description = product.metafields.global.description_tag.value | default: product.metafields.global.description_tag
  assign fitment_metafield = product.metafields.custom.fitment.value | default: product.metafields.custom.fitment
  assign fitment_notes = product.metafields.custom.fitment_notes.value | default: product.metafields.custom.fitment_notes
  assign fitment_make = product.metafields.custom.vehicle_make.value | default: product.metafields.custom.vehicle_make
  assign fitment_model = product.metafields.custom.vehicle_model.value | default: product.metafields.custom.vehicle_model
  assign fitment_chassis = product.metafields.custom.chassis.value | default: product.metafields.custom.chassis
  assign fitment_years = product.metafields.custom.years.value | default: product.metafields.custom.years

  if fitment_metafield != blank
    assign fitment_source = fitment_source | append: ' ' | append: fitment_metafield
  endif

  if seo_description != blank
    assign fitment_source = fitment_source | append: ' ' | append: seo_description
  endif

  if fitment_notes != blank
    assign fitment_source = fitment_source | append: ' ' | append: fitment_notes
  endif

  if fitment_make != blank
    assign fitment_source = fitment_source | append: ' ' | append: fitment_make
  endif

  if fitment_model != blank
    assign fitment_source = fitment_source | append: ' ' | append: fitment_model
  endif

  if fitment_chassis != blank
    assign fitment_source = fitment_source | append: ' ' | append: fitment_chassis
  endif

  if fitment_years != blank
    assign fitment_source = fitment_source | append: ' ' | append: fitment_years
  endif
-%}

<article class="product-card" data-product-card data-fitment-text="{{ fitment_source | strip_html | downcase | escape }}">
  <a href="{{ product.url }}" class="product-card__media" aria-label="{{ product.title | escape }}">
    {%- if product.featured_media -%}
      {{ product.featured_media | image_url: width: 820 | image_tag: loading: 'lazy', decoding: 'async', sizes: sizes, class: 'product-card__image' }}
      {%- if product.media[1] and product.media[1].media_type == 'image' -%}
        {{ product.media[1] | image_url: width: 820 | image_tag: loading: 'lazy', decoding: 'async', sizes: sizes, class: 'product-card__image product-card__image--hover' }}
      {%- endif -%}
    {%- else -%}
      <img src="{{ 'autobahn-hero.svg' | asset_url }}" alt="" width="1800" height="1000" loading="lazy" class="product-card__image">
    {%- endif -%}

    {%- if product.metafields.custom.badge != blank -%}
      <span class="product-card__badge">{{ product.metafields.custom.badge.value | default: product.metafields.custom.badge }}</span>
    {%- elsif product.tags contains 'New' -%}
      <span class="product-card__badge">New</span>
    {%- elsif product.available == false -%}
      <span class="product-card__badge">{{ 'products.product.sold_out' | t }}</span>
    {%- elsif product.compare_at_price > product.price -%}
      <span class="product-card__badge">{{ 'products.product.on_sale' | t }}</span>
    {%- endif -%}
  </a>

  <div class="product-card__info">
    {%- if product.vendor != blank -%}
      <div class="product-card__vendor">{{ product.vendor }}</div>
    {%- endif -%}
    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    {% render 'price', product: product %}
    {% render 'fitment-badge', product: product, context: 'card' %}
    {%- if product.available -%}
      {%- form 'product', product, class: 'product-card__quick-buy' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button class="button button--full" type="submit">{{ 'products.product.quick_buy' | t }}</button>
      {%- endform -%}
    {%- else -%}
      <a class="button button--secondary button--full" href="{{ product.url }}">{{ 'products.product.view_details' | t }}</a>
    {%- endif -%}
  </div>
</article>
