[
  {
    "name": "theme_info",
    "theme_name": "Autobahn Essentials",
    "theme_version": "5.4.0",
    "theme_author": "Codex",
    "theme_documentation_url": "https://help.shopify.com/en/manual/online-store/themes",
    "theme_support_url": "https://help.shopify.com/"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "checkbox",
        "id": "show_announcement",
        "label": "Show announcement bar",
        "default": true
      },
      {
        "type": "text",
        "id": "announcement_text",
        "label": "Announcement text",
        "default": "Built for drivers. Backed by passion."
      },
      {
        "type": "url",
        "id": "announcement_link",
        "label": "Announcement link"
      },
      {
        "type": "checkbox",
        "id": "show_ticker",
        "label": "Show header ticker",
        "default": true
      },
      {
        "type": "text",
        "id": "ticker_text",
        "label": "Ticker slogan",
        "default": "Built for drivers. Backed by passion."
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#08090A"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface",
        "default": "#151515"
      },
      {
        "type": "color",
        "id": "color_surface_strong",
        "label": "Strong surface",
        "default": "#262422"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text",
        "default": "#8e8e8e"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#e8432a"
      },
      {
        "type": "color",
        "id": "color_accent_contrast",
        "label": "Accent contrast",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_line",
        "label": "Lines",
        "default": "#282828"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_sticky_header",
        "label": "Enable sticky header",
        "default": true
      },
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "label": "Page width",
        "default": 1240
      }
    ]
  }
]
